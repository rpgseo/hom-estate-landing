# ─── Google Calendar ─────────────────────────────────────────────────────────
# JSON completo de las credenciales de la Service Account de Google Cloud
# Se obtiene en: Google Cloud Console > IAM > Cuentas de servicio > Claves
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}'

# ID del Google Calendar del coliving (aparece en Configuración del calendario)
# Ej: abc123xyz@group.calendar.google.com
GOOGLE_CALENDAR_ID=tu-calendario@group.calendar.google.com

# ─── Airtable ─────────────────────────────────────────────────────────────────
# Token personal de Airtable: https://airtable.com/create/tokens
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ID de la base de Airtable (aparece en la URL: airtable.com/appXXXXXXXXXXXXXX)
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# ─── Resend ──────────────────────────────────────────────────────────────────
# API Key de Resend: https://resend.com/api-keys
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Email donde llegan las notificaciones de leads
NOTIFY_EMAIL=ramonpg91@gmail.com

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Clave secreta de Stripe: https://dashboard.stripe.com/apikeys
# Formato real: sk_live_... (producción) o sk_test_... (pruebas)
STRIPE_SECRET_KEY=TU_STRIPE_SECRET_KEY_AQUI

# Secret del webhook de Stripe (se obtiene al crear el webhook en Stripe Dashboard)
# URL del webhook: https://tu-dominio.com/api/stripe/webhook
# Formato real: whsec_...
STRIPE_WEBHOOK_SECRET=TU_STRIPE_WEBHOOK_SECRET_AQUI

# ─── Seguridad interna ────────────────────────────────────────────────────────
# Token para el endpoint /api/stripe/create-link (solo uso interno del equipo)
# Genera uno aleatorio: openssl rand -hex 32
INTERNAL_API_TOKEN=genera-un-token-aleatorio-aqui

# ─── Retell AI ─────────────────────────────────────────────────────────────────────
# API Key de Retell (solo para backend): https://dashboard.retellai.com/keys
RETELL_API_KEY=tu-retell-api-key-aqui
# ID del Agente de Retell (público, para el widget)
PUBLIC_RETELL_AGENT_ID=tu-retell-agent-id-aqui
# Clave pública de Retell (para el widget web)
PUBLIC_RETELL_PUBLIC_KEY=tu-retell-public-key-aqui

# ─── Google reCAPTCHA v3 (opcional) ─────────────────────────────────────────────────
# Clave del sitio (Site Key) de Google reCAPTCHA v3: https://www.google.com/recaptcha/admin
PUBLIC_RECAPTCHA_SITE_KEY=
