{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"compatibility_date": "2026-06-25",
	"name": "hom-estate-landing",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"kv_namespaces": [
		{
			"binding": "SESSION",
			"id": "placeholder"
		}
	],
	"observability": {
		"enabled": true
	}
}
